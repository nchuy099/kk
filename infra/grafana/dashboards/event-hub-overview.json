{
  "id": null,
  "uid": "event-hub-overview",
  "title": "Event Hub Overview",
  "tags": [
    "event-hub",
    "microservices"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "style": "dark",
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "PROMETHEUS"
        },
        "query": {
          "query": "label_values(up, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$job\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Non-2xx Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$job\",status!~\"2..\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"$job\"}[5m])) by (job, le))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{job=~\"$job\"}) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{job=~\"$job\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DB Connections In Use",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{job=~\"$job\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RabbitMQ Queue Depth",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rabbitmq_queue_messages{queue=~\"^(order.payment-succeeded|ticket.order-paid|notification.ticket-issued)$\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "RabbitMQ Queue Consumers",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rabbitmq_queue_consumers{queue=~\"^(order.payment-succeeded|ticket.order-paid|notification.ticket-issued)$\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
